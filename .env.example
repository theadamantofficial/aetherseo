# Firebase Admin credentials for server-side payment routes.
# Use one of these:
# 1. FIREBASE_SERVICE_ACCOUNT_JSON with the full JSON inline
# 2. FIREBASE_SERVICE_ACCOUNT_PATH pointing to the downloaded service-account JSON file
# 3. GOOGLE_APPLICATION_CREDENTIALS pointing to the same JSON file
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_ADMIN_PROJECT_ID=rankly-9de82
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Optional. Defaults to test unless the Firestore document sets mode/live/prod.
RAZORPAY_MODE=test
